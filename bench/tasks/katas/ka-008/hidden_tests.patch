diff --git a/tests/ts/drift/hidden.test.ts b/tests/ts/drift/hidden.test.ts
new file mode 100644
index 0000000..09c25f2
--- /dev/null
+++ b/tests/ts/drift/hidden.test.ts
@@ -0,0 +1,34 @@
+import { expect, test } from "bun:test";
+import { driftEncode } from "../../../ts/drift.ts";
+
+test("drift with zero base shift", () => {
+  expect(driftEncode("abc", 0)).toBe("ace");
+});
+
+test("drift with positive base shift", () => {
+  expect(driftEncode("AAAA", 1)).toBe("BCDE");
+});
+
+test("non-letters pass through without advancing drift", () => {
+  expect(driftEncode("a b!c", 0)).toBe("a c!e");
+});
+
+test("wraps around the alphabet", () => {
+  expect(driftEncode("zz", 1)).toBe("ab");
+});
+
+test("negative shifts work", () => {
+  expect(driftEncode("bbb", -1)).toBe("abc");
+});
+
+test("case is preserved", () => {
+  expect(driftEncode("Hi", 2)).toBe("Jl");
+});
+
+test("empty string", () => {
+  expect(driftEncode("", 5)).toBe("");
+});
+
+test("non-integer shift throws RangeError", () => {
+  expect(() => driftEncode("abc", 0.5)).toThrow(RangeError);
+});
