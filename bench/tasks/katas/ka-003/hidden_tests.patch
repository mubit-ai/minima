+import pytest
+import intervals
+
+
+def test_empty():
+    assert intervals.merge_intervals([]) == []
+
+
+def test_unsorted_overlaps_merge():
+    assert intervals.merge_intervals([(5, 7), (1, 3), (2, 4)]) == [(1, 4), (5, 7)]
+
+
+def test_touching_merges_by_default():
+    assert intervals.merge_intervals([(1, 2), (2, 3)]) == [(1, 3)]
+
+
+def test_touching_kept_when_disabled():
+    assert intervals.merge_intervals([(1, 2), (2, 3)], merge_touching=False) == [(1, 2), (2, 3)]
+    assert intervals.merge_intervals([(1, 2.5), (2, 3)], merge_touching=False) == [(1, 3)]
+
+
+def test_contained_interval_absorbed():
+    assert intervals.merge_intervals([(1, 10), (2, 3), (4, 5)]) == [(1, 10)]
+
+
+def test_invalid_interval_raises():
+    with pytest.raises(ValueError):
+        intervals.merge_intervals([(3, 1)])
+
+
+def test_input_not_modified():
+    data = [(5, 7), (1, 3)]
+    intervals.merge_intervals(data)
+    assert data == [(5, 7), (1, 3)]
