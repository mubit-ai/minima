+import { describe, expect, test } from "bun:test";
+import { parseCsv, serializeCsv } from "../src/csv.ts";
+
+describe("carriage-return fields", () => {
+  test("quotes a field containing a bare carriage return", () => {
+    expect(serializeCsv([["a\rb"]])).toBe('"a\rb"');
+  });
+
+  test("round-trips fields containing bare carriage returns", () => {
+    const rows = [
+      ["x", "a\rb"],
+      ["y", "z"],
+    ];
+    expect(parseCsv(serializeCsv(rows))).toEqual(rows);
+  });
+});
