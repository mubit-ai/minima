+
+/** Bin values using explicit edges; see {@link HistogramOptions.edges}. */
+function histogramWithEdges(
+  values: ReadonlyArray<number>,
+  edges: ReadonlyArray<number>,
+): HistogramBin[] {
+  if (edges.length < 2) {
+    throw new RangeError("edges must contain at least two values");
+  }
+  for (let i = 1; i < edges.length; i++) {
+    if (!(edges[i]! > edges[i - 1]!)) {
+      throw new RangeError("edges must be strictly increasing");
+    }
+  }
+  const result: HistogramBin[] = [];
+  for (let b = 0; b < edges.length - 1; b++) {
+    result.push({ x0: edges[b]!, x1: edges[b + 1]!, count: 0 });
+  }
+  const lo = edges[0]!;
+  const hi = edges[edges.length - 1]!;
+  for (const v of values) {
+    if (v < lo || v > hi) continue;
+    let idx = result.length - 1;
+    if (v < hi) {
+      idx = 0;
+      while (v >= edges[idx + 1]!) idx += 1;
+    }
+    result[idx]!.count += 1;
+  }
+  return result;
+}
