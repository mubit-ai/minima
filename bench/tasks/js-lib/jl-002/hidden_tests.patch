+import { describe, expect, test } from "bun:test";
+import { median, quantile } from "../src/stats.ts";
+
+describe("quantile interpolation", () => {
+  test("interpolates between order statistics (R-7 rule)", () => {
+    expect(quantile([1, 2, 3, 4], 0.5)).toBe(2.5);
+    expect(quantile([15, 20, 35, 40, 50], 0.25)).toBe(20);
+    expect(quantile([10, 20, 30], 0.75)).toBe(25);
+    expect(quantile([1, 2], 0.5)).toBe(1.5);
+  });
+
+  test("median of even- and odd-length arrays", () => {
+    expect(median([1, 2, 3, 4])).toBe(2.5);
+    expect(median([3, 1, 2])).toBe(2);
+  });
+});
