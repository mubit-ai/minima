 import sliceAnsi from 'slice-ansi';
 import stringWidth from 'string-width';
 
+// slice-ansi rounds UP when a fullwidth character straddles the end boundary, so a
+// slice requested at N cells can come back N+1 wide. Re-slice until it actually fits —
+// a too-wide truncation overflows the terminal row and breaks inline renderers.
+function sliceWithin(text, begin, end) {
+	let out = sliceAnsi(text, begin, end);
+	while (end > begin && stringWidth(out) > end - begin) {
+		end -= 1;
+		out = sliceAnsi(text, begin, end);
+	}
+	return out;
+}
